# Copy this file to .env and fill in your actual credentials.
# ============================================================
# Environment Variables - Required for Analysis
# ============================================================

# GitHub Personal Access Token (required for API access)
GITHUB_TOKEN=

# Groq API Key (get one at https://console.groq.com)
GROQ_API_KEY=

# LLM Selection (Llama 3.1 8b is recommended for speed/efficiency)
LLM_MODEL=llama-3.1-8b-instant

# Log level
LOG_LEVEL=INFO

# Enable Vector Database (ChromaDB) for Semantic Search RAG
USE_VECTOR_DB=False
