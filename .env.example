# ============================================================
# Environment Variables - Copy this file to .env and fill in
# ============================================================

# GitHub Personal Access Token (required for API access)
GITHUB_TOKEN=your_github_personal_access_token

# Groq API Key (free — get one at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma_db

# Embedding model name (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM model name
LLM_MODEL=llama-3.3-70b-versatile

# Chunk size for document splitting
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Log level
LOG_LEVEL=INFO
